{
  "expo": {
    "name": "AttendEase AI",
    "slug": "attendease-ai",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0E15"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendease.ai"
    },
    "android": {
      "package": "com.attendease.ai",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0E15"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/60b67aa8-9656-4d73-b83f-ea7d1a1dfa6b",
      "checkAutomatically": "ON_APP_START",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "60b67aa8-9656-4d73-b83f-ea7d1a1dfa6b"
      }
    }
  }
}
